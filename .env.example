# AI Music Station Configuration
# Copy this file to .env and fill in values

# Database
DB_USER=app
DB_PASSWORD=changeme
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://app:changeme@localhost:5432/ai_music_station

# ACE-Step Configuration (host worker)
ACESTEP_API_URL=http://localhost:8001
ACESTEP_MODEL_PATH=/models/ace-step-v1.5
ACESTEP_DEVICE=mps

# Streaming
ICECAST_SOURCE_PASSWORD=changeme
ICECAST_ADMIN_PASSWORD=changeme

# Server
API_PORT=8000
FRONTEND_PORT=3200
