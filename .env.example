# AI Music Station Configuration
# Copy this file to .env and fill in values

# Database
DATABASE_URL=postgres://app:changeme@localhost:5432/ai_music_station

# ACE-Step Configuration
ACESTEP_MODEL_PATH=/models/ace-step-v1.5
ACESTEP_DEVICE=mps  # mps for Apple Silicon, cuda for NVIDIA

# Streaming
ICECAST_SOURCE_PASSWORD=changeme
ICECAST_ADMIN_PASSWORD=changeme

# Server
API_PORT=8000
FRONTEND_PORT=3200
NODE_ENV=production
