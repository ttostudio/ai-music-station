# AI Music Station 設定
# このファイルを .env にコピーして値を設定してください

# データベース
DB_USER=app
DB_PASSWORD=changeme
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://app:changeme@localhost:5432/ai_music_station

# ACE-Step 設定（ホストワーカー用）
ACESTEP_API_URL=http://localhost:8001
ACESTEP_MODEL_PATH=/models/ace-step-v1.5
ACESTEP_DEVICE=mps

# ストリーミング
ICECAST_SOURCE_PASSWORD=changeme
ICECAST_ADMIN_PASSWORD=changeme

# AI（歌詞・曲名生成） — claude CLI（ローカル）を使用
# CLAUDE_COMMAND=claude

# サーバー
API_PORT=8000
FRONTEND_PORT=3200

# 共有リンク・アナリティクス
PUBLIC_BASE_URL=http://localhost:3200
ANALYTICS_IP_SALT=changeme-random-salt
